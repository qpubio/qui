{
  "name": "@qpub/qui",
  "version": "0.1.0",
  "description": "QPub shared React UI primitives (shadcn-compatible, Tailwind + Radix)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qpub/qui"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./globals.css": "./dist/globals.css",
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.mjs",
      "require": "./dist/tailwind-preset.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "MIGRATION.md"
  ],
  "overrides": {
    "uuid": "^11.1.1",
    "glob": "^13.0.6"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup && node scripts/copy-static.mjs",
    "dev": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 -c docs/.storybook",
    "build-storybook": "STORYBOOK_DISABLE_TELEMETRY=1 CI=true storybook build -c docs/.storybook -o docs/storybook-static",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.542.0",
    "react": "^18 || ^19",
    "react-day-picker": "^9.8.0",
    "react-dom": "^18 || ^19",
    "react-resizable-panels": "^3.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3",
    "tailwindcss": "^3.4",
    "tailwindcss-animate": "^1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/node": "^22.15.17",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "10.3.6",
    "lucide-react": "^0.542.0",
    "postcss": "^8.5.4",
    "react": "^19.2.0",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^3.0.6",
    "sonner": "^2.0.7",
    "storybook": "^10.3.6",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.5.0",
